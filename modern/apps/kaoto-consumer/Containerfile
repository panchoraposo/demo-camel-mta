FROM registry.access.redhat.com/quarkus/mandrel-25-rhel9:latest AS build

USER 0
RUN microdnf install -y maven && microdnf clean all

WORKDIR /workspace
COPY modern modern

# Build native inside the Mandrel builder image.
RUN mvn -f modern/pom.xml -pl apps/kaoto-consumer -am package -DskipTests -Dquarkus.native.enabled=true -Dquarkus.package.jar.enabled=false -Dquarkus.native.additional-build-args=--trace-object-instantiation=java.net.Inet4Address

FROM registry.access.redhat.com/ubi9/ubi-micro:latest
WORKDIR /work
COPY --from=build /workspace/modern/apps/kaoto-consumer/target/*-runner /work/application

EXPOSE 8083
USER 1001
ENTRYPOINT ["/work/application","-Dquarkus.http.host=0.0.0.0"]

